# ─────────────────────────────────────────────────────────────────────────────
# Creek Lend — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local (Docker):  postgresql://creekuser:creekpassword@127.0.0.1:5433/creeklend?schema=public
# Production:      Use your managed DB provider's connection string (Neon, Supabase, RDS).
DATABASE_URL=postgresql://creekuser:creekpassword@127.0.0.1:5433/creeklend?schema=public

# ── Encryption ────────────────────────────────────────────────────────────────
# 64-character hex string (= 32 bytes) used for AES-256-CBC encryption of PII fields
# (SSN, Driver's License Number, Bank Account Number).
# Generate a secure key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key makes existing encrypted records unreadable. Back it up securely.
ENCRYPTION_KEY=replace_with_64_hex_characters

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express API listens on.
PORT=8000

# ── Meta Conversions API (CAPI) ───────────────────────────────────────────────
# Server-to-server event tracking — bypasses iOS privacy restrictions and ad-blockers.
# How to get these values:
#   1. Go to Meta Business Manager
#   2. Open Events Manager → [Your Pixel] → Settings
#   3. Scroll to "Conversions API" → click "Generate Access Token"
META_PIXEL_ID=your_pixel_id_here
META_ACCESS_TOKEN=your_capi_access_token_here

# Test Event Code (OPTIONAL — sandbox only)
# Allows you to see events in Meta Events Manager → "Test Events" tab
# without polluting live conversion data. Remove this in production.
META_TEST_EVENT_CODE=TEST12345
