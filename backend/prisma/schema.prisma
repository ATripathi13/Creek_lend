// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Borrower {
  id              String        @id @default(uuid())
  firstName       String
  lastName        String
  email           String        @unique
  phone           String
  applications    Application[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Application {
  id                   String      @id @default(uuid())
  borrowerId           String
  borrower             Borrower    @relation(fields: [borrowerId], references: [id])
  
  // Loan Details
  loanAmount           Decimal     @db.Decimal(10,2)
  status               String      @default("PENDING") // PENDING, APPROVED, REJECTED

  // Identification (Encrypted)
  encryptedSsn         String
  encryptedDlNumber    String
  dlState              String
  dob                  String      // Stored as string or DateTime, but controller uses string from form
  
  // Employment
  employerName         String?
  monthlyIncome        Decimal     @db.Decimal(10,2)
  incomeFrequency      String      // WEEKLY, BI_WEEKLY, MONTHLY
  
  // Banking
  routingNumber        String
  bankName             String?
  encryptedAccountNum  String
  
  // Tracking & Attribution
  utmTracking          UTMTracking?
  consentRecords       ConsentRecord[]
  
  createdAt            DateTime    @default(now())
}

model UTMTracking {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])
  source        String?
  medium        String?
  campaign      String?
  content       String?
  term          String?
}

model ConsentRecord {
  id                 String      @id @default(uuid())
  applicationId      String
  application        Application @relation(fields: [applicationId], references: [id])
  type               String      // TCPA, etc.
  agreed             Boolean     @default(false)
  ipAddress          String
  userAgent          String
  jornayaLeadId      String?
  trustedFormCertUrl String?
  tcpaAcceptedAt     DateTime    @default(now())
}
